<clickhouse>
  <users>
    <default>
      <!-- Allow access from Docker network and localhost -->
      <networks>
        <ip>::1</ip>
        <ip>127.0.0.1</ip>
        <ip>172.16.0.0/12</ip>  <!-- Docker default network range -->
        <ip>192.168.0.0/16</ip>  <!-- Docker custom networks -->
      </networks>
      <!-- No password for local development -->
      <password></password>
    </default>
  </users>
</clickhouse>