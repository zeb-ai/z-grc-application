# ==============================================
# DATABASE CONFIGURATION
# ==============================================
    # Choose your database type: postgres, mysql, sqlite, mssql, mongodb
DB_TYPE=postgres

# ==============================================
# POSTGRESQL CONFIGURATION
# ==============================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=pass
DB_NAME=db_name
DB_SSL=false

# ==============================================
# MYSQL CONFIGURATION (if DB_TYPE=mysql)
# ==============================================
# DB_HOST=localhost
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=pass
# DB_NAME=governance_engine

# ==============================================
# MONGODB CONFIGURATION (if DB_TYPE=mongodb)
# ==============================================
# Option 1: Use connection string (recommended)
# MONGODB_URI=mongodb://localhost:27017/governance_engine
# MONGODB_URI=mongodb://username:password@localhost:27017/governance_engine
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/governance_engine

# Option 2: Use individual settings
# DB_HOST=localhost
# DB_PORT=27017
# DB_USERNAME=
# DB_PASSWORD=
# DB_NAME=governance_engine

# ==============================================
# SQLITE CONFIGURATION (if DB_TYPE=sqlite)
# ==============================================
# DB_SQLITE_PATH=./data/governance.db

# ==============================================
# DATABASE OPTIONS
# ==============================================
# Auto-create/update tables (NEVER use true in production)
DB_SYNCHRONIZE=true

# Log all SQL queries
DB_LOGGING=true

# ==============================================
# CLICKHOUSE CONFIGURATION
# ==============================================
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# ==============================================
# AUTHENTICATION CONFIGURATION
# ==============================================
# JWT secret for signing tokens (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ==============================================
# SERVICE API KEYS (EXTERNAL APPLICATIONS)
# ==============================================
# Comma-separated service API keys for external applications to generate GRC keys
# Generate a key: node -e "console.log('sk_' + require('crypto').randomBytes(32).toString('hex'))"
# Example: SERVICE_API_KEYS=sk_abc123...,sk_xyz789...
SERVICE_API_KEYS=sk_your_service_key_here

# ==============================================
# GOVERNANCE ENGINE CONFIGURATION
# ==============================================
# Base URL for governance engine (optional, auto-detected from request if not set)
# GOVERNANCE_URL=https://governance.example.com

# OpenTelemetry endpoint (optional)
# OTEL_ENDPOINT=https://otel.example.com